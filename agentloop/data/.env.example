# AgentLoop configuration — copy to .env and edit.
#   cp .env.example .env

# Mode: cli (default) drives an external agent CLI; direct calls an OpenAI-compatible API.
AGENT_MODE=cli

# Primary harness: OpenCode (ships free models, needs no key from us).
# OpenCode is auto-detected if this is left unset; set explicitly to pin it.
AGENT_PRESET=opencode

# Other harnesses: kilocode | claude | aider | codex
# Or set AGENT_CMD to any command; the prompt is injected via $AGENTLOOP_PROMPT.
# AGENT_CMD='opencode run "$AGENTLOOP_PROMPT" --auto'

# Ground-truth verification oracle (run with cwd = project root).
# The agent can NEVER edit this, so it cannot fake success.
VERIFY_CMD="bash verify.sh"

# Optional: run the verifier every N direct-mode steps (early feedback). 0 = only on DONE.
# VERIFY_AT_STEP=0

# Optional: held-out oracle seal (passed to VERIFY_CMD only — never to the agent).
# ORACLE_SEAL=change-me-to-a-long-random-string

# Loop bounds
MAX_ITERS=50
# WALL_CLOCK_SEC=21600
# STEP_DELAY=3
# AGENT_TIMEOUT=900
# VERIFY_TIMEOUT=120

# Optional: fire on terminal states. {kind} and {msg} are substituted.
# NOTIFY_CMD='curl -s -X POST https://hooks.example.com -d "{kind}: {msg}"'

# Direct mode only (legacy) — leave unset when using a CLI harness.
# KILO_API_KEY=
# KILO_BASE_URL=https://api.kilo.ai/api/gateway
# KILO_MODEL=nvidia/nemotron-3-super-120b-a12b:free
