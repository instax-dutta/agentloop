# AgentLoop configuration
# Mode: cli (default) drives an external agent CLI; direct calls an OpenAI-compatible API.
AGENT_MODE=cli

# Primary harness: OpenCode (ships free models, needs no key from us).
# OpenCode is auto-detected if this is left unset; set explicitly to pin it.
AGENT_PRESET=opencode

# Other harnesses also work (uncomment to switch): kilocode | claude | aider | codex
# Or set AGENT_CMD to any command; the prompt is injected via $AGENTLOOP_PROMPT.

# Ground-truth verification oracle (run with cwd = project root).
# The agent can NEVER edit this, so it cannot fake success.
VERIFY_CMD="bash verify.sh"

# Optional: run the verifier every N iterations too (early feedback). 0 = only at the end.
VERIFY_AT_STEP=0

# Loop bounds
MAX_ITERS=50
STEP_DELAY=3
AGENT_TIMEOUT=900

# --- direct mode only (legacy / offline; not the intended path) ---
# KILO_API_KEY=sk-...
# KILO_BASE_URL=https://api.kilo.ai/api/gateway
# KILO_MODEL=nvidia/nemotron-3-super-120b-a12b:free
